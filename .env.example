# Django Settings
SECRET_KEY=tu-clave-secreta-super-segura-cambiala-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# USE_SQLITE=True para desarrollo (no requiere PostgreSQL)
# USE_SQLITE=False para producción con PostgreSQL
USE_SQLITE=True
DB_NAME=casa_repuestos
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=480  # 8 horas en minutos
JWT_REFRESH_TOKEN_LIFETIME=10080  # 7 días en minutos

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File uploads
MAX_UPLOAD_SIZE=10485760  # 10 MB

# Email (para futuras notificaciones)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-password

# Configuraciones del negocio
UMBRAL_STOCK_BAJO=2
UMBRAL_MARGEN_BAJO=5.0
DESCUENTO_MAX_CAJERO=50.0
PERMITIR_STOCK_NEGATIVO=True
